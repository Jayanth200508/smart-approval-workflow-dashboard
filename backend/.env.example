PORT=5051
JWT_SECRET=change_this_secret
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/
MONGODB_DB_NAME=flowpilot
ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
WORKFLOW_MONITOR_ENABLED=true
WORKFLOW_MONITOR_INTERVAL_MS=60000
WORKFLOW_INACTIVITY_THRESHOLD_HOURS=24
WORKFLOW_ESCALATION_THRESHOLD_HOURS=48
WORKFLOW_OVERLOAD_THRESHOLD=6
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=FlowPilot
SMTP_FROM_EMAIL=no-reply@flowpilot.com
DASHBOARD_URL=http://localhost:5173
